<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Living Collage with @wix/interact</title>
    <!-- Import Google Font 'Inter' -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    
    <!-- Import @wix/interact library -->
    <script type="module" src="https://esm.sh/@wix/interact@1.79.0"></script>

    <style>
        /* Base styles for a clean, fullscreen experience */
        html, body {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden; /* Hide scrollbars */
            background-color: #000;
            font-family: 'Inter', sans-serif;
        }

        /* Main container for the collage, acting as the interactive area */
        #collage-container {
            width: 100%;
            height: 100%;
            position: relative;
            cursor: pointer;
        }

        /* The wix-interact-element wrapper is made layout-neutral */
        wix-interact-element {
            display: contents;
        }

        /* Each image layer in the collage */
        .fragment {
            position: absolute;
            overflow: hidden;
            width: 100%;
            height: 100%;
            left: 0;
            top: 0;
            background-color: #111;
            /* The initial state (scale(0)) is now set declaratively by the 
               first keyframe of the @wix/interact animation. */
        }

        /* The image itself, styled as a background for perfect covering */
        .fragment .content-image {
            width: 100%;
            height: 100%;
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* Text overlay, which fades in on hover */
        .text-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            padding: max(20px, 4vw);
            box-sizing: border-box;
            color: #fff;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.7);
            
            /* Initial state is invisible */
            opacity: 0; 
            /* A simple CSS transition handles the fade effect */
            transition: opacity 0.4s ease-in-out;
        }

        /* On hover of the main wrapper, the text overlay becomes visible */
        wix-interact-element[data-wix-path="#collage-wrapper"]:hover .text-overlay {
            opacity: 1;
        }

        .text-overlay h1 {
            margin: 0 0 5px 0;
            font-size: clamp(1.8rem, 5vw, 2.5rem);
        }

        .text-overlay p {
            margin: 0;
            font-size: clamp(1rem, 2.5vw, 1.2rem);
            font-weight: 400;
        }
    </style>
</head>
<body>
    <!-- 
      This main wrapper handles the hover interaction for pausing the animation
      and for fading in the text overlay.
    -->
    <wix-interact-element data-wix-path="#collage-wrapper">
        <div id="collage-container">
            <!-- Fragments will be dynamically added here by JavaScript -->
        </div>
    </wix-interact-element>


    <script type="module">
        import { Interact } from 'https://esm.sh/@wix/interact@1.79.0';
        
        document.addEventListener('DOMContentLoaded', () => {

            // --- 1. @wix/interact Configuration ---
            // This config declaratively defines the entrance animation for new fragments.
            const interactConfig = {
                effects: {
                    'fragment-scale-in': {
                        keyframeEffect: {
                            name: 'fragment-scale-in',
                            keyframes: [
                                { transform: 'scale(0)' },
                                { transform: 'scale(1)' }
                            ]
                        },
                        duration: 1100,
                        easing: 'cubic-bezier(0.25, 1, 0.5, 1)',
                        fill: 'both' // Keeps the fragment at scale(1) after animating
                    }
                },
                interactions: [
                    {
                        // This interaction targets any element with the class '.collage-fragment-wrapper'
                        // and triggers as soon as it's added to the DOM and enters the viewport.
                        key: '.collage-fragment-wrapper',
                        trigger: 'viewEnter',
                        params: { type: 'once' }, // The animation runs only one time per element.
                        effects: [
                            { effectId: 'fragment-scale-in' }
                        ]
                    }
                ]
            };

            // --- 2. Initialize Interact ---
            Interact.create(interactConfig);

            // --- 3. Application Logic ---
            const container = document.getElementById('collage-container');
            let animationIntervalId = null;
            const intervalTime = 2000; // Time between new images

            // Function to get a new random image
            const getRealImageUrl = () => `https://picsum.photos/1200/800?random=${Math.random()}`;

            function createFragment(imageUrl) {
                // Create the wix-interact-element that will trigger the animation
                const wixElement = document.createElement('wix-interact-element');
                wixElement.className = 'collage-fragment-wrapper'; // Target for the 'viewEnter' interaction
                wixElement.dataset.wixPath = `fragment-${Date.now()}`; // Unique ID is good practice

                // Create the visual fragment structure
                const fragment = document.createElement('div');
                fragment.className = 'fragment';

                const content = document.createElement('div');
                content.className = 'content-image';
                content.style.backgroundImage = `url(${imageUrl})`;
                fragment.appendChild(content);

                // Add the text overlay to each fragment
                const textOverlay = document.createElement('div');
                textOverlay.className = 'text-overlay';
                const title = document.createElement('h1');
                title.textContent = 'A Fleeting Moment';
                const subtitle = document.createElement('p');
                subtitle.textContent = 'Hover to pause and take in the view.';
                textOverlay.appendChild(title);
                textOverlay.appendChild(subtitle);
                fragment.appendChild(textOverlay);

                // Put the visual fragment inside the interact wrapper
                wixElement.appendChild(fragment);

                return wixElement;
            }

            // Main function to drive the collage
            function animateCollage() {
                const imageUrl = getRealImageUrl();
                const preloader = new Image();

                // Preload the image to ensure it's ready before animating
                preloader.onload = () => {
                    // Remove old fragments after a delay
                    const oldFragments = container.querySelectorAll('wix-interact-element');
                    setTimeout(() => oldFragments.forEach(node => node.remove()), 1500);

                    // Create and append the new fragment. The 'viewEnter' trigger will
                    // automatically fire, running the 'fragment-scale-in' effect.
                    const fragmentWrapper = createFragment(imageUrl);
                    container.appendChild(fragmentWrapper);
                };

                preloader.onerror = () => console.error("Failed to load image:", imageUrl);
                preloader.src = imageUrl;
            }

            // --- 4. Interval and Hover-to-Pause Logic ---
            // This logic remains in JavaScript as it controls the application's
            // timing loop, which is outside the scope of @wix/interact's animation system.
            function startAnimation() {
                if (animationIntervalId === null) {
                    animateCollage(); // Animate immediately
                    animationIntervalId = setInterval(animateCollage, intervalTime);
                }
            }

            function stopAnimation() {
                clearInterval(animationIntervalId);
                animationIntervalId = null;
            }

            const wrapper = document.querySelector('wix-interact-element[data-wix-path="#collage-wrapper"]');
            
            // Pause and resume the JS interval on hover
            wrapper.addEventListener('mouseenter', stopAnimation);
            wrapper.addEventListener('mouseleave', startAnimation);

            // Initial start
            startAnimation();
        });
    </script>
</body>
</html>
