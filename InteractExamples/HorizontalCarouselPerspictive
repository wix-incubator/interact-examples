<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>3D Card Deck Scroll Animation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Import @wix/interact library -->
    <script type="module" src="https://esm.sh/@wix/interact@1.79.0"></script>
    <style>
        body {
            background-color: #ffffff;
            font-family: 'Inter', sans-serif;
            color: #f3f4f6;
        }

        /* 1. Main scrollable area to drive the animation */
        .scroll-section {
            height: 1000vh; /* Provides scrollable space */
        }

        /* 2. Sticky container that acts as the "viewport" for our animation */
        .sticky-wrapper {
            position: sticky;
            top: 0;
            height: 100vh;
            overflow: hidden;
            perspective: 2000px; /* Enables 3D space for child elements */
        }

        /* 3. The card element styles */
        .card {
            position: absolute;
            width: 500px;
            height: 600px;
            max-width: 70vw;
            top: 50%;
            left: 50%;
            border-radius: 1.5rem;
            overflow: hidden;
            background: #1f2937;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
            will-change: transform, opacity; /* Performance hint for the browser */
            /* Start all cards at the center before JS transforms them */
            transform: translate(-50%, -50%); 
        }

        .card-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
        }
        
        /* 4. New Dynamic Title Container */
        #dynamic-title-container {
            position: absolute;
            bottom: 10vh;
            left: 0;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            padding: 0 2rem;
            box-sizing: border-box;
            color: #000000; /* CHANGED: Was #ffffff */
            text-align: center;
            pointer-events: none; /* So it doesn't block mouse clicks */
        }
        
        #dynamic-title-text {
            display: inline-block;
            opacity: 0; /* Start hidden, JS will control opacity */
        }

        /* Styling for the text content injected by JS */
        #dynamic-title-text h2 {
            font-size: 2.25rem; /* 36px */
            line-height: 2.5rem; /* 40px */
            font-weight: 700;
            /* REMOVED: text-shadow */
        }
        #dynamic-title-text p {
            font-size: 1.25rem; /* 20px */
            line-height: 1.75rem; /* 28px */
            color: #000000; /* CHANGED: Was #d1d5db */
            /* REMOVED: text-shadow */
        }
        
    </style>
</head>
<body>

    <div class="scroll-section">
        <!-- The sticky wrapper is the trigger for the viewProgress animation -->
        <wix-interact-element data-wix-path=".sticky-wrapper">
            <div class="sticky-wrapper">
                
                <!-- Card 1 -->
                <wix-interact-element data-wix-path="#card-1">
                    <div id="card-1" class="card">
                        <img src="https://images.unsplash.com/photo-1462331940025-496dfbfc7564?q=80&w=2414" class="card-image" alt="Cosmic Landscape">
                        <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>

                <!-- Card 2 -->
                <wix-interact-element data-wix-path="#card-2">
                    <div id="card-2" class="card">
                        <img src="https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?q=80&w=2670" class="card-image" alt="Galaxy View">
                         <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>
                
                <!-- Card 3 -->
                <wix-interact-element data-wix-path="#card-3">
                    <div id="card-3" class="card">
                        <img src="https://images.unsplash.com/photo-1446776811953-b23d57bd21aa?q=80&w=2672" class="card-image" alt="Earth from Space">
                         <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>

                <!-- Card 4 -->
                <wix-interact-element data-wix-path="#card-4">
                    <div id="card-4" class="card">
                        <img src="https://images.unsplash.com/photo-1462331940025-496dfbfc7564?q=80&w=2414" class="card-image" alt="Nebula">
                         <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>

                <!-- Card 5 -->
                <wix-interact-element data-wix-path="#card-5">
                    <div id="card-5" class="card">
                        <img src="https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?q=80&w=2670" class="card-image" alt="Lunar Surface">
                         <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>

                <!-- Card 6 -->
                <wix-interact-element data-wix-path="#card-6">
                    <div id="card-6" class="card">
                        <img src="https://images.unsplash.com/photo-1462331940025-496dfbfc7564?q=80&w=2414" class="card-image" alt="Aurora Borealis">
                         <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>

                <!-- Card 7 -->
                <wix-interact-element data-wix-path="#card-7">
                    <div id="card-7" class="card">
                        <img src="https://images.unsplash.com/photo-1454789548928-9efd52dc4031?q=80&w=2680" class="card-image" alt="Astronaut">
                         <!-- Removed card-content div -->
                    </div>
                </wix-interact-element>

                <!-- New Dynamic Title Element -->
                <wix-interact-element data-wix-path="#dynamic-title-container">
                    <div id="dynamic-title-container">
                        <span id="dynamic-title-text">
                            <!-- Content is set by JS -->
                        </span>
                    </div>
                </wix-interact-element>

            </div>
        </wix-interact-element>
    </div>

    <script type="module">
        import { Interact } from 'https://esm.sh/@wix/interact@1.79.0';
        
        const cardCount = 7;
        const effects = [];

        // Define the animation path for all cards
        const animationKeyframes = [
            { offset: 0,    transform: 'translate(-50%, -50%) translateX(150%) translateZ(-900px) rotateY(-60deg) rotateX(15deg)', opacity: 0 },
            { offset: 0.3,  transform: 'translate(-50%, -50%) translateX(60%) translateZ(-300px) rotateY(-30deg) rotateX(5deg)', opacity: 1 },
            { offset: 0.5,  transform: 'translate(-50%, -50%) translateX(0) translateZ(0) rotateY(0deg) rotateX(0deg)', opacity: 1 },
            { offset: 0.7,  transform: 'translate(-50%, -50%) translateX(-60%) translateZ(-300px) rotateY(30deg) rotateX(-5deg)', opacity: 1 },
            { offset: 1,    transform: 'translate(-50%, -50%) translateX(-150%) translateZ(-900px) rotateY(60deg) rotateX(-15deg)', opacity: 0 }
        ];

        // --- NEW: Define the titles for each card ---
        const titles = [
            { title: "Stellar Nurseries", subtitle: "Where Stars Are Born" },
            { title: "Galactic Wonders", subtitle: "A Universe of Possibility" },
            { title: "Our Blue Planet", subtitle: "A fragile existence" },
            { title: "Cosmic Clouds", subtitle: "The Dust of Creation" },
            { title: "The Silent Moon", subtitle: "A Watcher in the Night" },
            { title: "Celestial Dance", subtitle: "The Northern Lights" },
            { title: "Final Frontier", subtitle: "The Journey Beyond" }
        ];
        
        // This will track which title is currently displayed
        let currentTitleIndex = -1;
        
        // Create a staggered animation for each card
        for (let i = 1; i <= cardCount; i++) {
            // CHANGED: Use (cardCount + 1) to create space for the last card's animation to finish
            const progressPerCard = 1 / (cardCount + 1); 
            const start = (i - 1) * progressPerCard;
            const end = start + progressPerCard * 2; // Make animations overlap

            // Card movement effect
            effects.push({
                key: `#card-${i}`,
                keyframeEffect: {
                    name: `card-move-${i}`,
                    keyframes: animationKeyframes
                },
                rangeStart: { name: 'cover', offset: { type: 'percentage', value: start * 100 } },
                rangeEnd: { name: 'cover', offset: { type: 'percentage', value: end * 100 } },
                easing: 'linear',
                fill: 'both'
            });

            // The card content fade effect has been removed from here
        }

        // --- NEW: Add a single customEffect to control the dynamic title ---
        effects.push({
            key: '#dynamic-title-container', // Target the container
            customEffect: (el, progress) => {
                const textEl = el.querySelector('#dynamic-title-text');
                if (!textEl) return;

                let newOpacity = 0;
                let newTitleIndex = -1;
                
                // Loop through each card's potential range to find the active one
                for (let i = 1; i <= cardCount; i++) {
                    // CHANGED: Use (cardCount + 1) here as well to match the card animation timing
                    const progressPerCard = 1 / (cardCount + 1);
                    const start = (i - 1) * progressPerCard;
                    const animationDuration = progressPerCard * 2;
                    
                    // NEW: Define the fade-in and fade-out points
                    // We'll fade in from 0.25 to 0.35 (of the card animation)
                    // Be solid from 0.35 to 0.65
                    // Fade out from 0.65 to 0.75
                    const fadeInStartPoint = start + 0.25 * animationDuration;
                    const fadeInEndPoint = start + 0.35 * animationDuration;
                    const fadeOutStartPoint = start + 0.65 * animationDuration;
                    const fadeOutEndPoint = start + 0.75 * animationDuration;
                    
                    if (progress >= fadeInStartPoint && progress < fadeInEndPoint) {
                        // Fading in
                        const rangeDuration = fadeInEndPoint - fadeInStartPoint;
                        if (rangeDuration > 0) {
                           newOpacity = (progress - fadeInStartPoint) / rangeDuration;
                        } else {
                           newOpacity = 1; // Avoid divide by zero
                        }
                        newTitleIndex = i - 1; // Array index
                        break;
                    } else if (progress >= fadeInEndPoint && progress <= fadeOutStartPoint) {
                        // Fully visible
                        newOpacity = 1;
                        newTitleIndex = i - 1;
                        break;
                    } else if (progress > fadeOutStartPoint && progress <= fadeOutEndPoint) {
                        // Fading out
                        const rangeDuration = fadeOutEndPoint - fadeOutStartPoint;
                         if (rangeDuration > 0) {
                           newOpacity = 1 - ((progress - fadeOutStartPoint) / rangeDuration);
                         } else {
                            newOpacity = 0; // Avoid divide by zero
                         }
                        newTitleIndex = i - 1; // Array index
                        break;
                    }
                }

                // Apply changes
                if (newTitleIndex !== -1) {
                    // We are in an active range
                    if (newTitleIndex !== currentTitleIndex) {
                        // Title needs to change
                        const newTitle = titles[newTitleIndex];
                        textEl.innerHTML = `<h2>${newTitle.title}</h2><p>${newTitle.subtitle}</p>`;
                        currentTitleIndex = newTitleIndex;
                    }
                    // Apply the calculated opacity
                    textEl.style.opacity = Math.max(0, Math.min(1, newOpacity));
                } else {
                    // Not in any range, ensure it's faded out
                    textEl.style.opacity = 0;
                    currentTitleIndex = -1; // Reset
                }
            },
            // This effect runs for the entire scroll duration
            rangeStart: { name: 'cover', offset: { type: 'percentage', value: 0 } },
            rangeEnd: { name: 'cover', offset: { type: 'percentage', value: 100 } },
            fill: 'both'
       });


        const config = {
            interactions: [{
                key: '.sticky-wrapper',
                trigger: 'viewProgress',
                effects: effects // Pass in the array of all card and title effects
            }]
        };

        Interact.create(config);
    </script>

</body>
</html>



