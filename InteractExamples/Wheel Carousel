<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Top-Arc Wheel Carousel</title>
    <!-- Import the Interact library -->
    <script type="module" src="https://esm.sh/@wix/interact@1.79.0"></script>
    <style>
        :root{
            --bg:#111214;
            --text:#e9eef2;
            --btn:#34d399;
            --wheel-radius: 480px;
            /* Slow Rotation Speed */
            --card-size: 170px;
            --card-radius: 24px;
            --spin-deg-per-sec: 3; 
            --center-zone-size: 0.3; /* Dead zone for stopping rotation (30% of viewport) */
        }

        *{box-sizing:border-box}
        body{
            margin:0; background:var(--bg); color:var(--text);
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial;
        }

        /* Viewport that only reveals the TOP arc */
        .arc-viewport{
            position:relative;
            height: 80vh;
            overflow:hidden;
            display:flex; align-items:flex-start; justify-content:center;
            padding-top: 5vh;
            /* Cursor feedback is handled dynamically */
        }

        /* The full circle lives lower than the viewport “floor” */
        .wheel{
            position:relative;
            width: calc(var(--wheel-radius) * 2 + var(--card-size));
            height: calc(var(--wheel-radius) * 2 + var(--card-size));
            transform: translateY(12%);
            pointer-events:none;
        }

        /* The wix-interact-element wrapper must be display: contents so it doesn't break the layout */
        wix-interact-element {
            display: contents;
        }

        .card{
            position:absolute; left:0; top:0;
            width: var(--card-size); height: var(--card-size);
            border-radius: var(--card-radius);
            overflow:hidden; background:#222; box-shadow: 0 10px 30px rgba(0,0,0,.35);
            transform-origin: 50% calc(var(--wheel-radius) + var(--card-size)/2);
            will-change: transform;
            pointer-events:auto;
            /* Changed cursor from 'pointer' to 'default' as cards are no longer clickable anchors */
            cursor: default; 
            transition: transform .2s ease; /* Retain CSS transition for click move */
        }

        /* Image needs initial state for Interact to animate FROM */
        .card img{
            width:100%; height:100%; object-fit:cover; display:block;
            /* Remove transform transition as Interact manages it */
        }

        .card:hover {
            z-index: 10;
        }

        .card[data-active="true"]{ box-shadow: 0 16px 40px rgba(0,0,0,.55); }

        .copy{
            text-align:center;
            margin:-24vh auto 80px;
            max-width: min(90vw, 900px);
            position: relative;
            z-index: 10;
        }
        .headline{ font-size: clamp(26px, 4.5vw, 60px); font-weight:300; letter-spacing:.01em; }
        .sub{ opacity:.75; margin-top:10px; font-size: clamp(13px, 1.8vw, 17px); }
        .cta{
            margin:24px auto 0; display:inline-block; background:var(--btn); color:#042;
            padding:14px 22px; border-radius:14px; font-weight:600; text-decoration:none;
            transition:transform .15s ease;
        }
        .cta:active{ transform:translateY(2px) }

        @media (max-width:900px){
            :root{
                --wheel-radius: 380px;
                --card-size: 140px;
            }
            .arc-viewport{ height: 70vh; }
            .copy{ margin-top: -19vh; }
        }
        @media (max-width:600px){
            :root{
                --wheel-radius: 280px;
                --card-size: 120px;
            }
            .arc-viewport{ height: 65vh; }
            .copy{ margin-top: -17vh; }
        }
    </style>
</head>
<body>

<wix-interact-element data-wix-path="#arcViewport">
    <section class="arc-viewport" id="arcViewport">
        <wix-interact-element data-wix-path="#wheel">
            <div class="wheel" id="wheel"></div>
        </wix-interact-element>
    </section>
</wix-interact-element>

<section class="copy">
    <div class="headline">25% Off All<br/>Top Rated Headphones</div>
    <div class="sub">Explore Limited Time Offers</div>
    <a class="cta" href="#">Get Started</a>
</section>

<script type="module">
    import { Interact } from 'https://esm.sh/@wix/interact@1.79.0';

    // --- Core Data ---
    const imgs = [
        'https://images.pexels.com/photos/3781523/pexels-photo-3781523.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1037992/pexels-photo-1037992.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/3587478/pexels-photo-3587478.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/205926/pexels-photo-205926.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/788946/pexels-photo-788946.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/3945659/pexels-photo-3945659.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/4009621/pexels-photo-4009621.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/5081403/pexels-photo-5081403.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1649771/pexels-photo-1649771.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1279813/pexels-photo-1279813.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1154039/pexels-photo-1154039.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/374630/pexels-photo-374630.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/2651794/pexels-photo-2651794.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/668383/pexels-photo-668383.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/2529170/pexels-photo-2529170.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/2775273/pexels-photo-2775273.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/3756943/pexels-photo-3756943.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/4549416/pexels-photo-4549416.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1029243/pexels-photo-1029243.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/355770/pexels-photo-355770.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/610916/pexels-photo-610916.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/2426085/pexels-photo-2426085.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/3825529/pexels-photo-3825529.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/937895/pexels-photo-937895.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1570264/pexels-photo-1570264.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/1105754/pexels-photo-1105754.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/211124/pexels-photo-211124.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/2582932/pexels-photo-2582932.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/3394658/pexels-photo-3394658.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/3186643/pexels-photo-3186643.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/4031323/pexels-photo-4031323.jpeg?auto=compress&cs=tinysrgb&w=600',
        'https://images.pexels.com/photos/577769/pexels-photo-577769.jpeg?auto=compress&cs=tinysrgb&w=600'
    ];

    // --- State and Config ---
    const wheel = document.getElementById('wheel');
    const cards = [];
    let radius = 0;
    let cardSize = 0;
    let step = 0;
    let baseAngle = -Math.PI / 2;
    // Set to 1 for continuous COUNTER-CLOCKWISE rotation
    let spinDirection = 1; 
    let last = performance.now();
    let speed = 0;

    // --- Core Functions ---

    function updateConfig() {
        radius = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--wheel-radius'));
        cardSize = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--card-size'));
        step = (2 * Math.PI) / imgs.length;
        const speedDegPerSec = parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--spin-deg-per-sec')) || 6;
        speed = (speedDegPerSec * Math.PI / 180);
    }

    function getCenter() {
        const w = wheel.clientWidth, h = wheel.clientHeight;
        return { cx: w / 2, cy: h / 2 };
    }

    function placeCards() {
        if (cards.length === 0) return;
        const { cx, cy } = getCenter();
        let activeIndex = 0, best = Infinity;

        cards.forEach((cardEl, i) => {
            const a = baseAngle + step * i;
            const x = cx + radius * Math.cos(a);
            const y = cy + radius * Math.sin(a);
            const deg = (a + Math.PI / 2) * (180 / Math.PI);
            const tx = x - cardSize / 2;
            const ty = y - cardSize / 2;
            cardEl.style.transform = `translate(${tx}px, ${ty}px) rotate(${deg}deg)`;

            // Topmost detection
            const diff = Math.abs(((a + 2 * Math.PI) % (2 * Math.PI)) - (3 * Math.PI / 2));
            if (diff < best) { best = diff; activeIndex = i; }

            // Update active state and opacity
            cardEl.dataset.active = (i === activeIndex).toString();
            // Subtle opacity fade for cards below the visible arc
            cardEl.style.opacity = (y <= cy + cardSize * 0.5) ? '1' : '0.2';
        });
    }

    function createCards() {
        updateConfig();
        wheel.innerHTML = '';
        imgs.forEach((src, i) => {
            // 1. Create wix-interact-element for the Card container (for click/hover trigger)
            const wixWrapper = document.createElement('wix-interact-element');
            wixWrapper.dataset.wixPath = `#card-${i}`;

            // CHANGED from 'a' to 'div' to remove implicit anchor click behavior
            const card = document.createElement('div');
            card.className = 'card';
            card.id = `card-${i}`;
            
            // 2. Create inner elements
            const imgWrapper = document.createElement('wix-interact-element');
            imgWrapper.dataset.wixPath = `#card-img-${i}`;
            imgWrapper.style.display = 'contents'; // Important for wrapping content

            const img = document.createElement('img');
            img.id = `card-img-${i}`;
            img.setAttribute('loading', 'lazy');
            img.src = src;
            img.alt = `carousel image ${i + 1}`;
            img.onerror = function() {
                this.onerror = null;
                this.src = 'https://placehold.co/170x170/222/FFF?text=Error';
            };

            // Append image to its wrapper
            imgWrapper.appendChild(img);
            
            // Append the image wrapper to the card
            card.appendChild(imgWrapper);

            // REMOVED: Click event listener that animated card centering
            /*
            card.addEventListener('click', (e) => {
                const idx = cards.indexOf(card);
                if (idx !== -1) {
                    e.preventDefault();
                    // Set base angle to move this card to the top (3*PI/2 position)
                    const target = 3 * Math.PI / 2;
                    baseAngle = target - step * idx;
                    placeCards();
                }
            });
            */

            wixWrapper.appendChild(card);
            wheel.appendChild(wixWrapper);
            cards.push(card);
        });
        placeCards();
    }

    function animate(now) {
        const dt = (now - last) / 1000;
        last = now;
        // The rotation logic
        if (spinDirection !== 0) {
            baseAngle += speed * spinDirection * dt;
        }
        placeCards();
        requestAnimationFrame(animate);
    }

    // --- Interact Configuration ---
    const cardInteractions = [];

    // Generate individual hover interactions for each card
    for (let i = 0; i < imgs.length; i++) {
        cardInteractions.push({
            key: `#card-${i}`, // The entire card is the hover trigger
            trigger: 'hover',
            params: {
                type: 'alternate' // Plays forward on enter, reverses on leave (Rule 1)
            },
            effects: [
                {
                    key: `#card-img-${i}`, // The inner image is the target
                    keyframeEffect: {
                        name: `image-scale-${i}`,
                        keyframes: [
                            { transform: 'scale(1)' },    // Start state (implicit)
                            { transform: 'scale(1.1)' }   // End state (hovered)
                        ]
                    },
                    fill: 'both',
                    duration: 300,
                    easing: 'ease-out'
                }
            ]
        });
    }

    const interactConfig = {
        interactions: [
            // 2. Continuous Animation Loop (Manages RAF) - No pointerMove control
            {
                key: '#wheel',
                trigger: 'pageVisible',
                params: {
                    type: 'state'
                },
                effects: [{
                    customEffect: (element, progress, params) => {
                        if (!element.dataset.animationStarted) {
                            // Start the physics animation loop
                            requestAnimationFrame(animate);
                            element.dataset.animationStarted = 'true';
                        }
                        // Set the spin direction to 1 for continuous counter-clockwise
                        spinDirection = 1; 
                    },
                    // No range needed, this just starts the process
                }]
            },
            // 3. Card Hover Effects (Combined from generated array)
            ...cardInteractions
        ]
    };

    // --- Initialization ---
    
    window.addEventListener('resize', () => {
        updateConfig();
        placeCards();
    });

    document.addEventListener('DOMContentLoaded', () => {
        // Ensure initial spin is counter-clockwise
        spinDirection = 1; 
        createCards();
        Interact.create(interactConfig);
    });
</script>
</body>
</html>
