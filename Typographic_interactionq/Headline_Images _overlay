<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wix Interact - Mask Reveal Animation</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Importing Xanh Mono, Liter, and Oswald */
        @import url('https://fonts.googleapis.com/css2?family=Xanh+Mono:ital@0;1&family=Liter:ital,wght@0,400;1,400&family=Oswald:wght@700&display=swap');

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: #000000; /* UPDATED: Black */
        }

        #header-section {
            position: relative;
            width: 100%;
            height: 100vh;
            overflow: hidden;
            isolation: isolate; /* Crucial for blend modes */
        }

        /* * Text Layout - The Single Instance
         * Z-Index 50: On top of masks
         * Mix-Blend-Mode: Difference
         */
        .content-layout {
            position: absolute;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 6vw;
            box-sizing: border-box;
            pointer-events: none;
            z-index: 50; /* Top layer */
            mix-blend-mode: difference;
        }

        /* * Text Styling
         * UPDATED: Color set to Very Light Grey (#e6e6e6). 
         * Logic:
         * Lighter Source (#e6e6e6) - Yellow BG = Darker Visual Grey.
         */
        .text-common {
            font-size: clamp(2.7rem, 8.8vw, 7.5rem); 
            line-height: 0.95;
            letter-spacing: -2px;
            color: #e6e6e6; 
        }

        .text-top {
            font-family: 'Liter', serif; /* UPDATED: Now matches bottom font */
            text-align: left;
            align-self: flex-start;
            max-width: 14ch;
            /* Removed specific letter-spacing override to match common style (-2px) */
            font-size: clamp(2.5rem, 8.5vw, 7.2rem);
        }

        .text-bottom {
            font-family: 'Liter', serif;
            text-align: right;
            align-self: flex-end;
            max-width: 12ch;
            word-spacing: 0;
        }

        /* Mask Items */
        .mask-item {
            position: absolute;
            left: var(--x);
            top: var(--y);
            width: var(--w);
            height: var(--h);
            clip-path: var(--clip);
            -webkit-mask-image: var(--mask);
            mask-image: var(--mask);
            overflow: hidden;
            z-index: 20; /* Behind Text */
            opacity: 0;
            will-change: opacity;
            background-color: #f3f4f6;
        }

        .mask-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            filter: grayscale(100%);
        }

        /* Shapes */
        .shape-square       { --clip: inset(0% 0% 0% 0%); --mask: none; }
        .shape-rect         { --clip: inset(0% 0% 0% 0%); --mask: none; } 
        .shape-circle       { --clip: circle(50% at 50% 50%); --mask: none; }
        .shape-triangle     { --clip: polygon(50% 0%, 0% 100%, 100% 100%); --mask: none; }
        .shape-oval         { --clip: ellipse(50% 40% at 50% 50%); --mask: none; }
        .shape-arch         { --clip: inset(0% 0% 0% 0% round 50% 50% 0 0); --mask: none; }
        .shape-pentagon     { --clip: polygon(50% 0%, 98% 35%, 79% 90%, 21% 90%, 2% 35%); --mask: none; }

    </style>
</head>
<body>

<interact-element data-interact-key="header-scene">
    <section id="header-section">
        
        <!-- Single Text Instance (Top Layer) -->
        <div class="content-layout">
            <h1 class="text-top text-common">Design is the future of everything</h1>
            <h1 class="text-bottom text-common">Crafted today for a better tomorrow</h1>
        </div>

        <!-- Mask Layers (No internal text) -->
        
        <!-- Mask 1 -->
        <interact-element data-interact-key="mask-1">
            <div class="mask-item shape-square" style="--x: 5vw; --y: 10vh; --w: 75vmin; --h: 75vmin;">
                <img src="https://images.unsplash.com/photo-1511497584788-876760111969?q=80&w=800&auto=format&fit=crop" class="mask-bg" alt="">
            </div>
        </interact-element>

        <!-- Mask 2 -->
        <interact-element data-interact-key="mask-2">
            <div class="mask-item shape-rect" style="--x: 82vw; --y: 0vh; --w: 18vw; --h: 100vh;">
                <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=800&auto=format&fit=crop" class="mask-bg" alt="">
            </div>
        </interact-element>

        <!-- Mask 3 -->
        <interact-element data-interact-key="mask-3">
            <div class="mask-item shape-pentagon" style="--x: -5vw; --y: 55vh; --w: 50vmin; --h: 50vmin;">
                <img src="https://images.unsplash.com/photo-1505118380757-91f5f5632de0?q=80&w=800&auto=format&fit=crop" class="mask-bg" alt="">
            </div>
        </interact-element>

        <!-- Mask 4 -->
        <interact-element data-interact-key="mask-4">
            <div class="mask-item shape-circle" style="--x: 50vw; --y: -5vh; --w: 45vmin; --h: 45vmin;">
                <img src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?q=80&w=800&auto=format&fit=crop" class="mask-bg" alt="">
            </div>
        </interact-element>

        <!-- Mask 5 -->
        <interact-element data-interact-key="mask-5">
            <div class="mask-item shape-arch" style="--x: 35vw; --y: 25vh; --w: 35vmin; --h: 50vmin;">
                <img src="https://images.unsplash.com/photo-1509316975850-ff9c5deb0cd9?q=80&w=800&auto=format&fit=crop" class="mask-bg" alt="">
            </div>
        </interact-element>

        <!-- Mask 6 -->
        <interact-element data-interact-key="mask-6">
            <div class="mask-item shape-oval" style="--x: 15vw; --y: 65vh; --w: 70vw; --h: 35vh;">
                <img src="https://images.unsplash.com/photo-1419242902214-272b3f66ee7a?q=80&w=800&auto=format&fit=crop" class="mask-bg" alt="">
            </div>
        </interact-element>

    </section>
</interact-element>

<script type="module">
    import { Interact } from 'https://esm.sh/@wix/interact@1.86.0';

    const STEP_DURATION = 0.8;
    const TOTAL_DURATION = STEP_DURATION * 6; // 4.8s

    const createSequencedKeyframes = (index, totalSteps) => {
        const stepSize = 1 / totalSteps; 
        const start = index * stepSize;
        const end = (index + 1) * stepSize;
        
        const frames = [];
        frames.push({ opacity: 0, offset: 0 });
        if (start > 0) {
            frames.push({ opacity: 0, offset: start });
        }
        frames.push({ opacity: 1, offset: start });
        frames.push({ opacity: 1, offset: end });
        if (end < 1) {
            frames.push({ opacity: 0, offset: end });
            frames.push({ opacity: 0, offset: 1 });
        }
        return frames;
    };

    const config = {
        interactions: [
            {
                key: 'header-scene',
                trigger: 'viewEnter',
                params: { type: 'once', threshold: 0 }, 
                effects: [
                    { key: 'mask-1', duration: TOTAL_DURATION * 1000, iterations: Infinity, keyframeEffect: { name: 'sequence-1', keyframes: createSequencedKeyframes(0, 6) } },
                    { key: 'mask-2', duration: TOTAL_DURATION * 1000, iterations: Infinity, keyframeEffect: { name: 'sequence-2', keyframes: createSequencedKeyframes(1, 6) } },
                    { key: 'mask-3', duration: TOTAL_DURATION * 1000, iterations: Infinity, keyframeEffect: { name: 'sequence-3', keyframes: createSequencedKeyframes(2, 6) } },
                    { key: 'mask-4', duration: TOTAL_DURATION * 1000, iterations: Infinity, keyframeEffect: { name: 'sequence-4', keyframes: createSequencedKeyframes(3, 6) } },
                    { key: 'mask-5', duration: TOTAL_DURATION * 1000, iterations: Infinity, keyframeEffect: { name: 'sequence-5', keyframes: createSequencedKeyframes(4, 6) } },
                    { key: 'mask-6', duration: TOTAL_DURATION * 1000, iterations: Infinity, keyframeEffect: { name: 'sequence-6', keyframes: createSequencedKeyframes(5, 6) } }
                ]
            }
        ]
    };
    Interact.create(config);
</script>

</body>
</html>
